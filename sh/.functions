# Create a new directory and enter it
function mkcd() {
    mkdir -p "$@" && cd "$_"
}

# Copy absolute path of file to clipboard
function abspath() {
    absp=$(realpath "$@" | tr -d '\n')
    echo $absp
    echo $absp | pbcopy
}

# Determine size of a file or total size of a directory
function fs() {
    if du -b /dev/null >/dev/null 2>&1; then
        local arg=-sbh
    else
        local arg=-sh
    fi
    if [[ -n "$@" ]]; then
        du $arg -- "$@"
    else
        du $arg .[^.]* ./*
    fi
}

# Git Clone to ~/repos directory
function clone() {
    if [[ -z "${VAR}" ]]; then
        pushd $REPOS_PATH
        git clone -v --progress --recurse-submodules --shallow-submodules $1
        popd
    else
        echo "could not file repos path"
    fi
}

# `tre` is a shorthand for `tree` with hidden files and color enabled, ignoring
# the `.git` directory, listing directories first. The output gets piped into
# `less` with options to preserve color and line numbers, unless the output is
# small enough for one screen.
function tre() {
    tree -aC -I '.git|node_modules|bower_components' --dirsfirst "$@" | less -FRNX
}

# follow symbolic links if needed
function where() {
    which "$@" | xargs ls -l
}

# cheatsheet update. See github.com/yairfine/cheatsheet
function csu {
    # update cheatsheet script
    pushd $REPOS_PATH/cheatsheet
    TEMPFILE=$(mktemp)
    git pull 2>&1 | tee $TEMPFILE
    grep -i -e "Already up to date." -e "fatal: Could not read from remote repository" $TEMPFILE &>/dev/null || sudo ./install.sh
    rm $TEMPFILE
    popd

    # update the cheatsheet
    setopt null_glob # https://zsh.sourceforge.io/Doc/Release/Options.html#index-NULLGLOB
    for dir in $REPOS_PATH/*-cheatsheet; do
        pushd $dir
        git pull
        cs -i .
        popd
    done
}

function _rgs_raw() {
    PATHS=$(printf '%s\n' "${RG_SEARCH_PATH//:/ }")
    EXPANDED_PATHS=$(eval "echo $PATHS")

    RIPGREP_CONFIG_PATH=$HOME/.config/ripgrep/config-rgs rg $@ $(printf '%s\n' $EXPANDED_PATHS)
}

function rgs() {
    _rgs_raw --no-filename --color=always $@ \
        | perl -pe 's/(.*)# ?(.*)/\n# $2\n$1/'
}

function rgse() {
    local cmd=$(_rgs_raw --no-filename $@ | fzf | sed 's/#.*//; s/[[:space:]]*$//')
    if [[ -n "$cmd" ]]; then
        print -z "$cmd"
    fi
}

function update {
    # update dotfiles
    pushd "$REPOS_PATH/dotfiles/"
    just update
    popd
}

# ssh-add all keys
function ssha {
    pushd "$HOME/.ssh"

    for file in *.pub; do
        [ -f "$file" ] || break
        key="$(basename $file .pub)"
        ssh-add $key
    done

    popd
}

# dd bytes with semi optimal block size. See alias ddr ddz ddfo
function ddb() {
    if [[ $# -ne 3 ]]; then
        echo "usage: ddb <input stream> <size in bytes> <output file>"
        return 1
    else
        STREAM=$1
        SIZE=$2
        OUTPUT=$3
    fi

    if [ ! -f $OUTPUT ]; then
        touch $OUTPUT
    fi

    if command -v getconf &>/dev/null; then
        BS=$(getconf PAGE_SIZE)
    else
        BS="4k"
    fi

    COUNT=$((SIZE / BS))
    TOTAL_FIRST=$((COUNT * BS))
    REMINDER=$((SIZE - TOTAL_FIRST))

    echo "writing $BS * $COUNT and then another $REMINDER (tot $SIZE)"

    if [[ $COUNT -eq 0 ]]; then
        dd if=$STREAM of=$OUTPUT seek=0 bs=1 count=$SIZE
        return 0
    fi

    dd if=$STREAM of=$OUTPUT seek=0 bs=$BS count=$COUNT
    dd if=$STREAM of=$OUTPUT seek=$TOTAL_FIRST bs=1 count=$REMINDER
}

function destroy() {
    if [ $# -eq 0 ]; then
        echo "Missing input file"
        return 1
    fi

    for filename in "$@"; do
        if [[ -f $filename ]]; then
            SIZE_BYTES=$(stat -f "%z" $filename)
            chmod u+w $filename
            for run in {1..2}; do
                ddr $SIZE_BYTES $filename
            done
            rm -v -i $filename
        else
            echo "file '$filename' not exists"
        fi
    done
}

function link_repos_here() {
    for repo in "$@"; do
        if [ -d "$REPOS_PATH/$repo" ]; then
            ln -s -v "$REPOS_PATH/$repo" .
        else
            echo "$repo not found"
        fi
    done
}

# source outer environments
function src() {
    if [ -f "$HOME/.profilepriv" ]; then
        source "$HOME/.profilepriv"
    fi

    source ${HOME}/scripts/.alias
    source ${REPOS_PATH}/scripts/.alias
}

# Search history and place selected command on the prompt
function fhist() {
    local cmd=$(fc -ln 1 | tail -r | awk '{sub(/^[[:space:]]+/,"")} !seen[$0]++' | fzf --height 40% --layout reverse)
    if [[ -n "$cmd" ]]; then
        print -z "$cmd"
    fi
}

function fssh() {
    local selected_host
    selected_host=$(egrep "^Host ([^*]+)$" $HOME/.ssh/config | sed 's/Host //' | fzf --height 40% --layout reverse)

    if [[ -n "$selected_host" ]]; then
        ssh "$selected_host"
    fi
}

# Browse and install Homebrew packages
function fbrew() {
    local inst=$(brew search $@ | fzf -m)

    if [[ $inst ]]; then
        for prog in $(echo $inst); do
            brew install $prog
        done
    fi
}

# Open file in VSCode with optional line:col - searches subdirs if not found
codel() {
    [ $# -eq 0 ] && { echo "Usage: codel <file[:line[:col]]>"; return 1; }

    local arg="$1" filename="${1%%:*}" line_col="${1#*:}"
    [[ "$arg" == "$line_col" ]] && line_col=""

    if [ ! -f "$filename" ]; then
        local found=$(fd --hidden -t f "^$(basename "$filename")$" 2>/dev/null)
        [ -z "$found" ] && { echo "File '$filename' not found"; return 1; }

        local count=$(echo "$found" | wc -l | tr -d ' ')
        if [ "$count" -eq 1 ]; then
            filename="$found"
            echo "Found: $filename"
        else
            filename=$(echo "$found" | fzf --prompt="Select file: " --height=40% --reverse) || return 1
        fi
    fi

    code --goto "${filename}${line_col:+:$line_col}"
}

# upload a directory full of files to dropbox, skipping already-uploaded files by content hash
dbx_putr() {
    if [ $# -ne 2 ]; then
        echo "Usage: $0 <src dir> <dst dir>"
        echo "Example: $0 '/Users/yair/Downloads/photos/mytrip' '/Photos/mytrip'"
        return 1
    fi

    local src_dir="$1"
    local dst_dir="$2"
    local total_files

    if [ ! -d "$src_dir" ]; then
        echo "Error: Source directory '$src_dir' does not exist"
        return 1
    fi

    total_files=$(fd . "$src_dir" -t f | wc -l)

    if [ -n "$NTHREADS" ]; then
        threads="$NTHREADS"
    else
        threads="1"
    fi

    echo "Found $total_files files..."

    local large_files
    large_files=$(fd . --base-directory "$src_dir" -t f --size +100m)
    if [ -n "$large_files" ]; then
        local large_count
        large_count=$(echo "$large_files" | wc -l | tr -d ' ')
        echo "Skipping $large_count files over 100MB:"
        echo "$large_files" | sed 's/^/  /'
        echo ""
    fi

    echo "Uploading eligible files from '$src_dir' to '$dst_dir'..."
    echo "Using $threads threads"
    echo ""

    echo "Fetching remote hashes..."
    local hash_file
    hash_file=$(mktemp)
    dbx-remote-dir-hashes "$dst_dir" > "$hash_file"
    echo "Found $(wc -l < "$hash_file" | tr -d ' ') files on remote"
    echo ""

    fd -j "$threads" . "$src_dir" -t f --size -100m -x sh -c '
    src_dir="$(realpath "$1")"
    dst_dir="$2"
    hash_file="$3"
    src_file="$(realpath "{}")"
    relpath="${src_file#${src_dir}/}"
    dst_file="$dst_dir/$relpath"

    local_hash=$(dbx-content-hash "$src_file")

    if rg --quiet --line-regexp "$local_hash" "$hash_file"; then
        echo "SKIP (identical): $relpath"
    else
        echo "UPLOAD: $relpath"
        dbxcli put "$src_file" "$dst_file"
    fi
    ' _ "$src_dir" "$dst_dir" "$hash_file"

    rm -f "$hash_file"
}

# Retry dbx_putr until all files are uploaded or max retries reached
dbx_putr_retry() {
    if [ $# -ne 2 ]; then
        echo "Usage: dbx_putr_retry <src dir> <dst dir>"
        return 1
    fi

    echo "Starting"

    local max_retries="${DBX_MAX_RETRIES:-10}"
    local attempt=1
    local output

    while [ "$attempt" -le "$max_retries" ]; do
        echo "=== Attempt $attempt/$max_retries ==="
        output=$(NTHREADS="${NTHREADS:-4}" dbx_putr "$1" "$2" 2>&1 | tee /dev/tty)

        if ! echo "$output" | rg --quiet "^UPLOAD:"; then
            echo ""
            echo "All files uploaded successfully."
            break
        fi

        echo ""
        echo "Some uploads remaining, retrying in 5s..."
        sleep 5
        attempt=$((attempt + 1))
    done

    if [ "$attempt" -gt "$max_retries" ]; then
        echo "Gave up after $max_retries attempts. Some files may not have been uploaded." >&2
    fi

    local local_count remote_count large_count eligible
    local_count=$(fd . "$1" -t f | wc -l | tr -d ' ')
    large_count=$(fd . "$1" -t f --size +100m | wc -l | tr -d ' ')
    eligible=$((local_count - large_count))
    remote_count=$(dbx-remote-dir-hashes "$2" | wc -l | tr -d ' ')

    echo ""
    echo "=== Verification ==="
    echo "Local files:  $local_count"
    echo "Remote files: $remote_count"
    if [ "$large_count" -gt 0 ]; then
        echo "Skipped (>100MB): $large_count"
        echo "Eligible: $eligible"
    fi
    if [ "$remote_count" -ge "$eligible" ]; then
        echo "All eligible files accounted for."
    else
        echo "WARNING: File count mismatch! (expected: $eligible, got: $remote_count)" >&2
    fi
}
