# Don't let ripgrep vomit really long lines to my terminal, and show a preview.
# --max-columns=240
--max-columns-preview

# Search hidden files / directories (e.g. dotfiles) by default
--hidden

# exclude .git database dir
--glob=!.git/

# case insensitively
--ignore-case

# don't show line numbers
--no-line-number
