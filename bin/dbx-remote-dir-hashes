#!/bin/sh
# List all content hashes for files in a remote Dropbox directory (recursive)
# Outputs one content_hash per line
set -e

if [ $# -ne 1 ]; then
    echo "Usage: dbx-remote-dir-hashes <remote_dir>" >&2
    exit 1
fi

remote_dir="$1"
auth="$HOME/.config/dbxcli/auth.json"

# dbxcli >=3.7.0 stores an OAuth object under .[""].personal
# (access_token/refresh_token/expiry). Older versions stored the token string
# directly. Handle both.
token=$(jq -r '
    .[""].personal as $p
    | if   ($p | type) == "object" then ($p.access_token // empty)
      elif ($p | type) == "string" then $p
      else empty end
' "$auth")
if [ -z "$token" ] || [ "$token" = "null" ]; then
    echo "Error: no Dropbox access token in $auth (run 'dbxcli login')" >&2
    exit 1
fi

# Fail loudly on unreachable API / bad auth rather than emitting zero hashes:
# a silent empty result makes callers re-upload everything on every retry.
check_response() {
    if [ -z "$1" ]; then
        echo "Error: empty response from Dropbox API (check auth/network)" >&2
        exit 1
    fi
    if echo "$1" | jq -e '.error' >/dev/null 2>&1; then
        summary=$(echo "$1" | jq -r '.error_summary')
        case "$summary" in
            # Remote dir not created yet == zero files; not an error.
            path/not_found*) exit 0 ;;
            *) echo "Error: $summary" >&2; exit 1 ;;
        esac
    fi
}

response=$(curl -s -X POST https://api.dropboxapi.com/2/files/list_folder \
    -H "Authorization: Bearer $token" \
    -H "Content-Type: application/json" \
    -d "{\"path\": \"$remote_dir\", \"recursive\": true}")

check_response "$response"

echo "$response" | jq -r '.entries[] | select(.content_hash) | .content_hash'

while [ "$(echo "$response" | jq -r '.has_more')" = "true" ]; do
    cursor=$(echo "$response" | jq -r '.cursor')
    response=$(curl -s -X POST https://api.dropboxapi.com/2/files/list_folder/continue \
        -H "Authorization: Bearer $token" \
        -H "Content-Type: application/json" \
        -d "{\"cursor\": \"$cursor\"}")
    check_response "$response"
    echo "$response" | jq -r '.entries[] | select(.content_hash) | .content_hash'
done
