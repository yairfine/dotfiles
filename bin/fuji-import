#!/usr/bin/env bash
# Import a Fujifilm SD card: rsync to ~/Downloads, verify clones, prepare
# captures, then upload to Dropbox.
set -euo pipefail

src="/Volumes/Untitled/DCIM/100_FUJI"
date=$(LC_TIME=C date "+%Y-%b-%d")
camera="xt50"
dst="$HOME/Downloads/fujifilm $camera $date"
dbx_dst="/Photos/Fujifilm/$camera/$date"

if [ ! -d "$src" ]; then
    echo "Error: SD card not found at $src" >&2
    exit 1
fi

mkdir -p "$dst"
caffeinate -i -m -s -u rsync -avhP "$src/" "$dst"

fclones_output=$(fclones group "$src/" "$dst" | tee /dev/tty)
src_count=$(fd . "$src" -t f | wc -l | tr -d ' ')
clone_groups=$(echo "$fclones_output" | awk '/^# Total:/ { print $(NF-1) }')
if [ "$clone_groups" != "$src_count" ]; then
    echo "ERROR: Expected $src_count clone groups but found ${clone_groups:-0}" >&2
    exit 1
fi
echo "Clone check passed: $clone_groups/$src_count files verified"

prepare_fuji_captures.sh "$dst"
dbx-putr-retry "$dst" "$dbx_dst"

echo "$dst"
echo "Done"
